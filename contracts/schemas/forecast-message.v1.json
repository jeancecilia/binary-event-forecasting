{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://binary-event-research/schemas/forecast-message.v1.json",
  "title": "ForecastMessage",
  "description": "A forecast message from the Python intelligence plane (IPC-003). Schema version 1.",
  "type": "object",
  "required": [
    "schema_version", "message_id", "sender_instance_id", "sender_sequence",
    "market_id", "contract_or_outcome_id", "market_definition_version",
    "event_id", "underlying_event_group_id", "forecast_target", "forecast_horizon",
    "source_id", "source_version", "evidence_set_hash",
    "published_at", "first_source_available_at", "ingested_at", "revision_id",
    "model_artifact_hash", "model_training_cutoff", "ensemble_version",
    "component_model_versions", "prompt_version", "retrieval_corpus_version",
    "calibration_model_version", "calibration_training_cutoff",
    "raw_model_probability", "calibrated_probability",
    "uncertainty_lower", "uncertainty_upper",
    "uncertainty_coverage_level", "uncertainty_method",
    "decision_cutoff_at", "forecast_created_at", "forecast_emitted_at", "expires_at"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "message_id": { "type": "string", "format": "uuid" },
    "sender_instance_id": { "type": "string" },
    "sender_sequence": { "type": "integer", "minimum": 0 },
    "market_id": { "type": "string" },
    "contract_or_outcome_id": { "type": "string" },
    "market_definition_version": { "type": "string" },
    "event_id": { "type": "string" },
    "underlying_event_group_id": { "type": "string" },
    "forecast_target": { "type": "string" },
    "forecast_horizon": { "type": "string" },
    "source_id": { "type": "string" },
    "source_version": { "type": "string" },
    "evidence_set_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "published_at": { "type": "string", "format": "date-time" },
    "first_source_available_at": { "type": "string", "format": "date-time" },
    "ingested_at": { "type": "string", "format": "date-time" },
    "revision_id": { "type": "string" },
    "model_artifact_hash": { "type": "string" },
    "model_training_cutoff": { "type": "string", "format": "date-time" },
    "ensemble_version": { "type": "string" },
    "component_model_versions": { "type": "object" },
    "prompt_version": { "type": "string" },
    "retrieval_corpus_version": { "type": "string" },
    "calibration_model_version": { "type": "string" },
    "calibration_training_cutoff": { "type": "string", "format": "date-time" },
    "raw_model_probability": { "type": "integer", "minimum": 0, "maximum": 1000000 },
    "calibrated_probability": { "type": "integer", "minimum": 0, "maximum": 1000000 },
    "uncertainty_lower": { "type": "integer", "minimum": 0, "maximum": 1000000 },
    "uncertainty_upper": { "type": "integer", "minimum": 0, "maximum": 1000000 },
    "uncertainty_coverage_level": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
    "uncertainty_method": { "type": "string" },
    "abstention_reason": { "type": ["string", "null"] },
    "decision_cutoff_at": { "type": "string", "format": "date-time" },
    "forecast_created_at": { "type": "string", "format": "date-time" },
    "forecast_emitted_at": { "type": "string", "format": "date-time" },
    "expires_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
