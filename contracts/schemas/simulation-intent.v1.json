{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://binary-event-research/schemas/simulation-intent.v1.json",
  "title": "SimulationIntent",
  "description": "A deterministic simulation intent derived from a forecast message (FCP-002).",
  "type": "object",
  "required": [
    "simulation_intent_id", "experiment_id", "source_forecast_message_id",
    "forecast_policy_version", "configuration_hash", "market_id",
    "contract_or_outcome_id", "forecast_target", "order_class", "book_side",
    "outcome_side", "quantity", "price_limit", "time_in_force",
    "policy_priority", "decision_timestamp", "simulated_arrival_timestamp",
    "latency_scenario_version", "matching_model_version", "cost_model_version",
    "acknowledgement_latency_version", "cancellation_latency_version",
    "account_state_version", "input_snapshot_version", "expires_at"
  ],
  "properties": {
    "simulation_intent_id": { "type": "string" },
    "experiment_id": { "type": "string" },
    "source_forecast_message_id": { "type": "string" },
    "forecast_policy_version": { "type": "string" },
    "configuration_hash": { "type": "string" },
    "market_id": { "type": "string" },
    "contract_or_outcome_id": { "type": "string" },
    "forecast_target": { "type": "string" },
    "order_class": { "enum": ["ImmediateAllOrNone", "Passive"] },
    "book_side": { "enum": ["Bid", "Ask"] },
    "outcome_side": { "enum": ["Yes", "No"] },
    "quantity": { "type": "integer", "minimum": 0 },
    "price_limit": { "type": "integer", "minimum": 0 },
    "time_in_force": { "enum": ["ImmediateOrCancel", "GoodTillCancelled", "FillOrKill", "Day"] },
    "policy_priority": { "type": "integer", "minimum": 0 },
    "decision_timestamp": { "type": "string", "format": "date-time" },
    "simulated_arrival_timestamp": { "type": "string", "format": "date-time" },
    "latency_scenario_version": { "type": "string" },
    "matching_model_version": { "type": "string" },
    "cost_model_version": { "type": "string" },
    "acknowledgement_latency_version": { "type": "string" },
    "cancellation_latency_version": { "type": "string" },
    "account_state_version": { "type": "string" },
    "input_snapshot_version": { "type": "string" },
    "expires_at": { "type": "string", "format": "date-time" }
  },
  "additionalProperties": false
}
