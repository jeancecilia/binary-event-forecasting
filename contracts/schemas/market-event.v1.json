{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://binary-event-research/schemas/market-event.v1.json",
  "title": "MarketEvent",
  "description": "A market data event (trade, quote, snapshot, etc.).",
  "type": "object",
  "required": ["event_id", "market_id", "event_type", "source_timestamp", "logical_timestamp"],
  "properties": {
    "event_id": { "type": "string" },
    "market_id": { "type": "string" },
    "event_type": {
      "enum": ["trade", "quote_update", "order_book_delta", "order_book_snapshot", "feed_status_change", "settlement", "correction"]
    },
    "source_timestamp": { "type": "string", "format": "date-time" },
    "logical_timestamp": { "type": "integer" },
    "source_sequence": { "type": "integer" },
    "payload": { "type": "object" }
  },
  "additionalProperties": false
}
